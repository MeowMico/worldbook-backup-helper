{
  "name": "worldbook-workbench-vscode",
  "displayName": "Worldbook Workbench",
  "description": "Edit, batch-manage, version, and preview SillyTavern worldbooks in VS Code or Cursor.",
  "version": "0.2.2",
  "publisher": "meowmico",
  "private": true,
  "license": "MIT",
  "icon": "media/icon.png",
  "preview": true,
  "pricing": "Free",
  "galleryBanner": {
    "color": "#1b1d22",
    "theme": "dark"
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/MeowMico/worldbook-backup-helper.git",
    "directory": "packages/vscode-extension"
  },
  "homepage": "https://github.com/MeowMico/worldbook-backup-helper/tree/main/packages/vscode-extension",
  "bugs": {
    "url": "https://github.com/MeowMico/worldbook-backup-helper/issues"
  },
  "vsce": {
    "dependencies": false
  },
  "engines": {
    "vscode": "^1.88.0"
  },
  "categories": [
    "Other",
    "Visualization"
  ],
  "keywords": [
    "sillytavern",
    "worldbook",
    "lorebook",
    "character card",
    "prompt preview",
    "prompt engineering",
    "snapshot",
    "diff",
    "cursor",
    "roleplay",
    "json"
  ],
  "activationEvents": [
    "onCommand:worldbookWorkbench.openWorkbench",
    "onCommand:worldbookWorkbench.importCharacterCard",
    "onCommand:worldbookWorkbench.openPromptPreview",
    "onCommand:worldbookWorkbench.saveScenario",
    "onCommand:worldbookWorkbench.exportWorldbookJson"
  ],
  "main": "./extension.js",
  "contributes": {
    "commands": [
      {
        "command": "worldbookWorkbench.openWorkbench",
        "title": "Worldbook Workbench: Open Worldbook Workbench"
      },
      {
        "command": "worldbookWorkbench.importCharacterCard",
        "title": "Worldbook Workbench: Import Character Card"
      },
      {
        "command": "worldbookWorkbench.openPromptPreview",
        "title": "Worldbook Workbench: Open Prompt Preview"
      },
      {
        "command": "worldbookWorkbench.saveScenario",
        "title": "Worldbook Workbench: Save Scenario"
      },
      {
        "command": "worldbookWorkbench.exportWorldbookJson",
        "title": "Worldbook Workbench: Export Worldbook JSON"
      }
    ],
    "menus": {
      "explorer/context": [
        {
          "command": "worldbookWorkbench.openWorkbench",
          "when": "resourceExtname == .json",
          "group": "navigation@80"
        }
      ],
      "editor/title/context": [
        {
          "command": "worldbookWorkbench.openPromptPreview",
          "when": "resourceExtname == .json",
          "group": "navigation@80"
        }
      ]
    }
  },
  "scripts": {
    "build": "node scripts/build-package.mjs",
    "vscode:prepublish": "npm run build",
    "check": "npm run build && node --check scripts/build-package.mjs && node --check scripts/package-marketplace.mjs && node --check extension.js && node --check dist/core/index.js && node --check dist/webview/main.js && node --check dist/webview/scenario-fields.js && node --check dist/webview/worldbook-editor.js",
    "package:openvsx": "node scripts/package-marketplace.mjs openvsx",
    "package:microsoft": "node scripts/package-marketplace.mjs microsoft"
  },
  "devDependencies": {
    "@types/vscode": "^1.88.0"
  }
}
